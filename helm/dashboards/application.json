{
  "title": "Application Metrics - Employee App",
  "uid": "app-metrics",
  "panels": [
    {"title":"HTTP Request Rate","type":"timeseries","gridPos":{"h":8,"w":12,"x":0,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum(rate(flask_http_request_total{namespace=\"employee-app\"}[5m])) by (method, endpoint)","legendFormat":"{{method}} {{endpoint}}"}]},
    {"title":"HTTP Error Rate (5xx)","type":"timeseries","gridPos":{"h":8,"w":12,"x":12,"y":0},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum(rate(flask_http_request_total{namespace=\"employee-app\", status=~\"5..\"}[5m])) by (endpoint)","legendFormat":"{{endpoint}}"}]},
    {"title":"Request Duration (p95)","type":"timeseries","gridPos":{"h":8,"w":12,"x":0,"y":8},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"histogram_quantile(0.95, sum(rate(flask_http_request_duration_seconds_bucket{namespace=\"employee-app\"}[5m])) by (le, endpoint))","legendFormat":"{{endpoint}}"}]},
    {"title":"Active Connections","type":"stat","gridPos":{"h":8,"w":12,"x":12,"y":8},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum(nginx_connections_active{namespace=\"employee-app\"})","legendFormat":"Active"}]},
    {"title":"CPU Throttling","type":"timeseries","gridPos":{"h":8,"w":12,"x":0,"y":16},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum(rate(container_cpu_cfs_throttled_seconds_total{namespace=\"employee-app\"}[5m])) by (pod)","legendFormat":"{{pod}}"}]},
    {"title":"Network I/O","type":"timeseries","gridPos":{"h":8,"w":12,"x":12,"y":16},"datasource":{"type":"prometheus","uid":"prometheus"},"targets":[{"expr":"sum(rate(container_network_receive_bytes_total{namespace=\"employee-app\"}[5m])) by (pod) / 1024","legendFormat":"RX {{pod}} (KB/s)"},{"expr":"sum(rate(container_network_transmit_bytes_total{namespace=\"employee-app\"}[5m])) by (pod) / 1024","legendFormat":"TX {{pod}} (KB/s)"}]}
  ],
  "schemaVersion": 38,
  "time": {"from": "now-1h", "to": "now"},
  "refresh": "30s"
}
